// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // Agents.
  "document_symbols": "on",
  "document_folding_ranges": "on",
  "semantic_tokens": "combined",
  "diagnostics": {
    "inline": {
      "enabled": true
    }
  },
  "ui_font_weight": 400.0,
  "git_panel": {
    "tree_view": true
  },
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },

  // Theme.
  "inlay_hints": {
    "show_background": false,
    "enabled": true,
  },
  "theme": {
    "mode": "system",
    "light": "Arcadia Light",
    "dark": "Arcadia Dark",
  },
  "icon_theme": {
    "mode": "light",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },

  // Buffer
  "buffer_font_family": "Geist Mono",
  "buffer_font_size": 11.0,
  "buffer_font_weight": 400.0,
  "buffer_line_height": "comfortable",
  "tab_size": 2,
  "unnecessary_code_fade": 0.5,

  // Wrap guides.
  "preferred_line_length": 100,
  "show_wrap_guides": true,

  // Files.
  "autosave": "on_focus_change",
  "format_on_save": "off",

  // Gutters.
  "gutter": {
    "line_numbers": true,
  },

  // AI.
  "edit_predictions": {
    "provider": "copilot",
  },

  // UI.
  "ui_font_family": "Geist Mono",
  "ui_font_size": 13.0,
  "project_panel": {
    "entry_spacing": "standard",
    "folder_icons": false,
    "indent_size": 12,
  },

  // Terminal.
  "terminal": {
    "cursor_shape": "block",
    "font_size": 10.0
  },

  // Languages.
  "lsp_document_colors": "inlay",
  "languages": {
    "Ruby": {
      "format_on_save": "off",
      "language_servers": ["ruby-lsp", "rubocop", "!solargraph"],
      "preferred_line_length": 100,
    },
    "JavaScript": {
      "format_on_save": "off",
      "formatter": [],
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.fixAll.eslint": true,
      },
    },
    "Vue.js": {
      "format_on_save": "off",
      "formatter": [],
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.fixAll.eslint": true,
      },
    },
  },

  // Telemetry.
  "telemetry": {
    "metrics": false,
    "diagnostics": false,
  },
}
