# Git utilites.

check_git_config() {
  git config --get user.name >/dev/null && \
  git config --get user.email >/dev/null
}

# Configure git for a new machine.
# Machine-specific overrides (user.name, user.email) go in ~/.gitconfig.local.
configure_git() {
  read -p "What name do you use for git? " git_name
  git config --file $HOME/.gitconfig.local user.name "$git_name"

  read -p "What email do you use for git? " git_email
  git config --file $HOME/.gitconfig.local user.email "$git_email"

  # Install LFS - https://git-lfs.github.com.
  git lfs install
}
